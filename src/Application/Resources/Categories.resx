  <data name="Gift"><value>Presente</value></data>
  <data name="Pix"><value>Pix</value></data>
  <data name="BankTransfer"><value>Transferência Bancária</value></data>
  <data name="OtherIncome"><value>Outros</value></data>

  <!-- Expense -->
  <data name="Housing"><value>Casa</value></data>
  <data name="Education"><value>Educação</value></data>
  <data name="Electronics"><value>Eletrônicos</value></data>
  <data name="Leisure"><value>Lazer</value></data>
  <data name="OtherExpense"><value>Outros</value></data>
  <data name="Restaurant"><value>Restaurante</value></data>
  <data name="Health"><value>Saúde</value></data>
  <data name="Services"><value>Serviços</value></data>
  <data name="Grocery"><value>Supermercado</value></data>
  <data name="Transportation"><value>Transporte</value></data>
  <data name="Clothing"><value>Vestuário</value></data>
  <data name="Travel"><value>Viagem</value></data>
</root>
